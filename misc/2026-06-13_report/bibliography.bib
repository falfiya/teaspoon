@article{capsules,
	location = {Berlin, Heidelberg},
	title = {Computing with Capsules},
	volume = {7386},
	isbn = {978-3-642-31622-7 978-3-642-31623-4},
	url = {http://link.springer.com/10.1007/978-3-642-31623-4_1},
	doi = {10.1007/978-3-642-31623-4_1},
	abstract = {Capsules provide an algebraic representation of the state of a computation in higherorder functional and imperative languages. A capsule is essentially a ﬁnite coalgebraic representation of a regular closed λ-coterm. One can give an operational semantics based on capsules for a higher-order programming language with functional and imperative features, including mutable bindings. Static (lexical) scoping is captured purely algebraically without stacks, heaps, or closures. All operations of interest are typable with simple types, yet the language is Turing complete. Recursive functions are represented directly as capsules without the need for ﬁxpoint combinators.},
	pages = {1--19},
	booktitle = {Descriptional Complexity of Formal Systems},
	publisher = {Springer Berlin Heidelberg},
	author = {Jeannin, Jean-Baptiste and Kozen, Dexter},
	editor = {Kutrib, Martin and Moreira, Nelma and Reis, Rogério},
	editorb = {Hutchison, David and Kanade, Takeo and Kittler, Josef and Kleinberg, Jon M. and Mattern, Friedemann and Mitchell, John C. and Naor, Moni and Nierstrasz, Oscar and Pandu Rangan, C. and Steffen, Bernhard and Sudan, Madhu and Terzopoulos, Demetri and Tygar, Doug and Vardi, Moshe Y. and Weikum, Gerhard},
	editorbtype = {redactor},
	urldate = {2026-04-10},
	date = {2012},
	langid = {english},
	note = {Series Title: Lecture Notes in Computer Science},
	file = {PDF:C\:\\Users\\Alf\\Zotero\\storage\\U2PHQTDM\\Jeannin and Kozen - 2012 - Computing with Capsules.pdf:application/pdf},
}

